<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stage of Destiny — Gala Night | May 31, 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --gold: #C9993A;
  --gold-bright: #F0C040;
  --gold-light: #E8C87A;
  --gold-pale: #F5E6C0;
  --black: #050505;
  --black-mid: #0F0F0F;
  --black-soft: #1A1A1A;
  --white: #FFFFFF;
  --off-white: #F9F4EC;
  --muted: #8A7A60;
  --border: rgba(201,153,58,0.3);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Montserrat', sans-serif;
  background: var(--black);
  color: var(--off-white);
  overflow-x: hidden;
}

/* SHIMMER ANIMATION */
@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}

@keyframes float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-8px) rotate(2deg); }
  66% { transform: translateY(-4px) rotate(-1deg); }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0); }
  50% { opacity: 1; transform: scale(1); }
}

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 200;
  padding: 18px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(5,5,5,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}

.nav-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--gold-light);
  letter-spacing: 0.08em;
  font-style: italic;
}

.nav-links {
  display: flex;
  gap: 32px;
  list-style: none;
}

.nav-links a {
  font-size: 11px;
  font-weight: 500;
  color: rgba(255,255,255,0.5);
  text-decoration: none;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--gold-light); }

.nav-btn {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 50%, var(--gold) 100%);
  background-size: 200% auto;
  color: var(--black);
  border: none;
  padding: 10px 24px;
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  transition: background-position 0.4s, transform 0.2s;
}

.nav-btn:hover {
  background-position: right center;
  transform: translateY(-1px);
}

/* FEATHER SVG */
.feather {
  position: absolute;
  opacity: 0.12;
  pointer-events: none;
}

.feather svg { width: 100%; height: 100%; }

/* HERO */
.hero {
  min-height: 100vh;
  background: var(--black);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 120px 48px 100px;
  text-align: center;
}

.hero-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201,153,58,0.14) 0%, transparent 65%),
    radial-gradient(ellipse at 10% 80%, rgba(201,153,58,0.06) 0%, transparent 40%),
    radial-gradient(ellipse at 90% 10%, rgba(201,153,58,0.06) 0%, transparent 40%);
  pointer-events: none;
}

/* Glitter particles */
.glitter {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}

.glitter-dot {
  position: absolute;
  width: 3px;
  height: 3px;
  background: var(--gold-bright);
  border-radius: 50%;
  animation: sparkle var(--dur) ease-in-out infinite;
  animation-delay: var(--delay);
}

/* Feathers in hero */
.hero-feather-left {
  position: absolute;
  left: -40px;
  bottom: 0;
  width: 320px;
  height: 600px;
  opacity: 0.18;
  transform: rotate(-15deg);
}

.hero-feather-right {
  position: absolute;
  right: -40px;
  bottom: 0;
  width: 320px;
  height: 600px;
  opacity: 0.18;
  transform: rotate(15deg) scaleX(-1);
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: 820px;
  animation: fadeUp 1s ease both;
}

.hero-eyebrow {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.45em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 24px;
  padding: 8px 20px;
  border: 1px solid var(--border);
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(56px, 10vw, 110px);
  font-weight: 700;
  line-height: 0.92;
  color: var(--white);
  margin-bottom: 8px;
  letter-spacing: 0.02em;
}

.hero-title-gold {
  font-style: italic;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 40%, var(--gold-light) 60%, var(--gold) 100%);
  background-size: 300% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 4s linear infinite;
}

.hero-of {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(28px, 4vw, 48px);
  font-style: italic;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.3em;
  display: block;
  margin: 4px 0;
}

.hero-subtitle {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(14px, 2vw, 18px);
  font-style: italic;
  font-weight: 300;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.12em;
  margin: 24px 0 12px;
}

.hero-tribute {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.2em;
  color: var(--gold-light);
  text-transform: uppercase;
  margin-bottom: 48px;
  line-height: 2;
}

.hero-divider {
  display: flex;
  align-items: center;
  gap: 16px;
  justify-content: center;
  margin-bottom: 44px;
}

.hero-divider-line {
  width: 80px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.hero-divider-diamond {
  width: 6px;
  height: 6px;
  background: var(--gold);
  transform: rotate(45deg);
}

.hero-meta {
  display: flex;
  gap: 0;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 52px;
  border: 1px solid var(--border);
}

.hero-meta-item {
  padding: 20px 36px;
  text-align: center;
  border-right: 1px solid var(--border);
}

.hero-meta-item:last-child { border-right: none; }

.hero-meta-label {
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}

.hero-meta-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 18px;
  font-weight: 600;
  color: var(--white);
  line-height: 1.3;
}

.hero-ctas {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-gold {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 50%, var(--gold) 100%);
  background-size: 200% auto;
  color: var(--black);
  border: none;
  padding: 16px 44px;
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  transition: background-position 0.4s, transform 0.2s;
}

.btn-gold:hover { background-position: right center; transform: translateY(-2px); }

.btn-outline {
  background: transparent;
  color: var(--gold-light);
  border: 1px solid var(--border);
  padding: 16px 44px;
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
  transition: all 0.2s;
}

.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

/* SECTIONS */
section { padding: 100px 48px; }

.section-inner { max-width: 1040px; margin: 0 auto; }

.section-eyebrow {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--gold);
  display: block;
  margin-bottom: 16px;
}

.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(36px, 5vw, 60px);
  font-weight: 700;
  line-height: 1.05;
  color: var(--white);
  margin-bottom: 20px;
}

.section-title em { font-style: italic; color: var(--gold-light); }

.gold-line {
  width: 60px;
  height: 2px;
  background: linear-gradient(90deg, var(--gold), var(--gold-bright));
  margin-bottom: 40px;
}

/* ABOUT */
.about { background: var(--black-soft); }

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}

.about p {
  font-size: 15px;
  font-weight: 300;
  line-height: 1.95;
  color: rgba(255,255,255,0.6);
  margin-bottom: 20px;
}

.about-highlight {
  border-left: 2px solid var(--gold);
  padding: 20px 24px;
  background: rgba(201,153,58,0.05);
  margin: 32px 0;
}

.about-highlight p {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-style: italic;
  font-weight: 400;
  color: var(--gold-light) !important;
  margin: 0 !important;
  line-height: 1.6;
}

.about-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}

.about-stat {
  background: var(--black-soft);
  padding: 32px 24px;
  text-align: center;
}

.about-stat-num {
  font-family: 'Cormorant Garamond', serif;
  font-size: 48px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 8px;
}

.about-stat-label {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
}

/* TICKETS */
.tickets { background: var(--black); }

.ticket-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 48px;
}

.ticket-card {
  border: 1px solid var(--border);
  padding: 48px 40px;
  background: var(--black-soft);
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s, transform 0.3s;
}

.ticket-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.ticket-card:hover { border-color: var(--gold); transform: translateY(-4px); }
.ticket-card:hover::before { opacity: 1; }

.ticket-card.featured {
  border-color: var(--gold);
  background: linear-gradient(135deg, var(--black-soft) 0%, rgba(201,153,58,0.06) 100%);
}

.ticket-card.featured::before { opacity: 1; }

.ticket-badge {
  position: absolute;
  top: 20px; right: 20px;
  background: var(--gold);
  color: var(--black);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 4px 12px;
}

.ticket-type {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
}

.ticket-price {
  font-family: 'Cormorant Garamond', serif;
  font-size: 72px;
  font-weight: 700;
  color: var(--white);
  line-height: 1;
  margin-bottom: 8px;
}

.ticket-price sup {
  font-size: 28px;
  vertical-align: top;
  margin-top: 14px;
  display: inline-block;
  color: var(--gold);
}

.ticket-desc {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  margin-bottom: 32px;
  line-height: 1.8;
}

.ticket-perks {
  list-style: none;
  margin-bottom: 40px;
}

.ticket-perks li {
  font-size: 13px;
  font-weight: 400;
  color: rgba(255,255,255,0.65);
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex;
  gap: 12px;
  align-items: center;
}

.ticket-perks li::before {
  content: '◆';
  color: var(--gold);
  font-size: 7px;
  flex-shrink: 0;
}

.ticket-note {
  text-align: center;
  margin-top: 40px;
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  font-style: italic;
}

/* PERFORMERS */
.performers { background: var(--black-soft); }

.performers-intro {
  font-size: 15px;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  line-height: 1.9;
  max-width: 600px;
  margin-bottom: 60px;
}

.performers-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.performers-section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
  max-width: 200px;
}

.performer-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 48px;
}

.performer-card {
  border: 1px solid var(--border);
  padding: 32px 24px;
  text-align: center;
  background: var(--black);
  transition: border-color 0.2s;
}

.performer-card:hover { border-color: var(--gold); }

.performer-initial {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(201,153,58,0.15), rgba(201,153,58,0.05));
  border: 1px solid var(--border);
  margin: 0 auto 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 28px;
  font-style: italic;
  color: var(--gold);
}

.performer-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 6px;
  line-height: 1.3;
}

.performer-role {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
}

.special-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.special-card {
  border: 1px solid rgba(201,153,58,0.15);
  padding: 24px 20px;
  text-align: center;
  background: rgba(201,153,58,0.03);
}

.special-badge {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(201,153,58,0.1);
  padding: 3px 10px;
  display: inline-block;
  margin-bottom: 12px;
}

.special-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 4px;
  line-height: 1.3;
}

.special-desc {
  font-size: 11px;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  font-style: italic;
  line-height: 1.6;
}

/* SCHEDULE */
.schedule { background: var(--black); }

.schedule-list {
  margin-top: 48px;
  border-top: 1px solid var(--border);
}

.schedule-item {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 40px;
  padding: 32px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  align-items: start;
  transition: background 0.2s;
}

.schedule-item:hover { background: rgba(201,153,58,0.02); }

.schedule-time {
  font-family: 'Cormorant Garamond', serif;
  font-size: 26px;
  font-weight: 600;
  color: var(--gold);
  line-height: 1;
}

.schedule-ampm {
  font-size: 11px;
  letter-spacing: 0.2em;
  color: rgba(255,255,255,0.3);
  text-transform: uppercase;
  margin-top: 4px;
}

.schedule-event {
  font-family: 'Cormorant Garamond', serif;
  font-size: 22px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 6px;
}

.schedule-detail {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1.8;
}

/* COORDINATORS */
.coordinators { background: var(--black-soft); }

.coord-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
  margin-top: 48px;
}

.coord-card {
  text-align: center;
  padding: 40px 24px;
  border: 1px solid var(--border);
  background: var(--black);
}

.coord-initial {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(201,153,58,0.2), rgba(201,153,58,0.05));
  border: 2px solid var(--gold);
  margin: 0 auto 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 36px;
  font-style: italic;
  color: var(--gold-light);
}

.coord-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 24px;
  font-weight: 600;
  color: var(--white);
  margin-bottom: 6px;
}

.coord-title {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
}

.coord-contact {
  font-size: 13px;
  font-weight: 300;
  color: rgba(255,255,255,0.4);
  line-height: 1.8;
}

.coord-contact a {
  color: var(--gold-light);
  text-decoration: none;
}

/* LOCATION */
.location { background: var(--black); }

.location-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
  margin-top: 48px;
}

.location-details {
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.location-item {
  padding-left: 20px;
  border-left: 2px solid var(--gold);
}

.location-item-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}

.location-item-value {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-weight: 400;
  color: var(--white);
  line-height: 1.5;
}

.location-item-value a {
  color: var(--gold-light);
  text-decoration: none;
}

.map-container {
  border: 1px solid var(--border);
  overflow: hidden;
  aspect-ratio: 1;
}

.map-container iframe {
  width: 100%;
  height: 100%;
  border: none;
  filter: grayscale(40%) invert(10%);
}

/* CAUSE */
.cause {
  background: linear-gradient(135deg, var(--black-soft) 0%, rgba(201,153,58,0.06) 100%);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 80px 48px;
  text-align: center;
}

.cause p {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(18px, 3vw, 26px);
  font-style: italic;
  font-weight: 400;
  color: rgba(255,255,255,0.7);
  max-width: 700px;
  margin: 0 auto;
  line-height: 1.7;
}

.cause p span { color: var(--gold-light); }

/* FOOTER */
footer {
  background: var(--black);
  padding: 70px 48px 40px;
  text-align: center;
  border-top: 1px solid var(--border);
  position: relative;
  overflow: hidden;
}

.footer-feather {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0.04;
  pointer-events: none;
}

.footer-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 36px;
  font-weight: 700;
  font-style: italic;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-bright) 50%, var(--gold) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 4s linear infinite;
  margin-bottom: 12px;
}

.footer-tagline {
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.25);
  margin-bottom: 32px;
}

.footer-contact {
  display: flex;
  gap: 40px;
  justify-content: center;
  flex-wrap: wrap;
